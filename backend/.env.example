# ── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/medassist

# ── JWT — CHANGE THESE TO STRONG RANDOM STRINGS IN PRODUCTION ────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_strong_random_string_min_32_chars
JWT_ACCESS_SECRET=CHANGE_ME_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_different_strong_random_string_min_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Admin account ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@medassist.com
ADMIN_PASSWORD=your_hashed_password_here

# ── Frontend URL (used for CORS) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# For additional allowed origins, comma-separate:
# ALLOWED_ORIGINS=https://staging.medassist.com,https://app.medassist.com

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Auth0 (optional — leave empty to use email/password only) ─────────────────
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Inter-service authentication — shared secret between Node backend and Python AI service
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_SERVICE_SECRET=your_strong_random_secret_here

# Redis URL — required for distributed rate limiting when running multiple Node instances
# Leave blank in single-instance local dev
# REDIS_URL=redis://localhost:6379
