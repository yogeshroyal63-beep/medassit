# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare JavaScript/TypeScript/JSX as text
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.py   text eol=lf
*.sh   text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.pkl  binary
