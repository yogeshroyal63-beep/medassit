{
  "name": "medassist-healthcare-platform",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.12.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0",
    "helmet": "^7.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-validator": "^7.0.1",
    "passport": "^0.7.0",
    "passport-auth0": "^1.4.3",
    "express-openid-connect": "^2.17.1",
    "jwks-rsa": "^3.1.0",
    "ioredis": "^5.3.2",
    "rate-limit-redis": "^4.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFilesAfterEnv": [],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "runInBand": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/config/db.js"
    ],
    "coverageThresholds": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 60,
        "statements": 70
      }
    },
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
