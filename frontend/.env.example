# ── API ────────────────────────────────────────────────────────────────────────
# URL of the Node.js backend
VITE_API_BASE_URL=http://localhost:5001/api/v1

# ── WebSocket ──────────────────────────────────────────────────────────────────
# Real-time messaging / notifications (Socket.IO)
VITE_WS_URL=http://localhost:5001

# ── Auth0 (optional — leave empty to use email/password only) ─────────────────
# Create a Single Page Application in your Auth0 tenant and copy the values here
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
# Must match a URI in Auth0 > Application > Allowed Callback URLs
VITE_AUTH0_CALLBACK_URL=http://localhost:5173/auth/callback

# ── AI Service ─────────────────────────────────────────────────────────────────
# Direct URL if frontend calls the Python triage service (optional — the backend
# proxies triage by default; only set this for local AI-only development)
# VITE_AI_SERVICE_URL=http://localhost:8000
